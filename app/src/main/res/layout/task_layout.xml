<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="10dp">

    <!-- Reminder title -->
    <TextView
        android:id="@+id/taskListTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Reminder description -->
    <TextView
        android:id="@+id/taskListDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- Due date, time, owner and location info -->
    <TextView
        android:id="@+id/taskListDue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- Reminder photo if one was taken -->
    <ImageView
        android:id="@+id/taskListImage"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="#DDDDDD"
        android:scaleType="fitCenter" />

    <!-- Buttons for each reminder row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Opens the reminder for editing -->
        <Button
            android:id="@+id/editButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Edit" />

        <!-- Uploads the reminder to Firebase -->
        <Button
            android:id="@+id/shareButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Share" />

        <!-- Deletes the reminder locally -->
        <Button
            android:id="@+id/deleteButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Delete" />
    </LinearLayout>
</LinearLayout>
